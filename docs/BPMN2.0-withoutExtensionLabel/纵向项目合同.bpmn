<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/bpmn" id="Definitions_researchProjectContractFillProcess" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <process id="researchProjectContractFillProcess" name="科研项目合同书填写流程" isExecutable="true">
    <laneSet id="LaneSet_researchProjectContractFillProcess">
      <lane id="Lane_School" name="学校">
        <flowNodeRef>SchoolSealTask</flowNodeRef>
      </lane>
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>ScienceOfficeReviewTask</flowNodeRef>
        <flowNodeRef>ArchiveContractTask</flowNodeRef>
        <flowNodeRef>ScienceOfficeReviewGateway</flowNodeRef>
        <flowNodeRef>ApprovedEndEvent</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptReviewTask</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>FillContractTask</flowNodeRef>
        <flowNodeRef>PrintPdfContractTask</flowNodeRef>
        <flowNodeRef>LeaderSignTask</flowNodeRef>
      </lane>
      <lane id="Lane_Authority" name="科技主管部门/专业机构">
        <flowNodeRef>AuthorityApproveProjectTask</flowNodeRef>
        <flowNodeRef>AuthoritySealTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewGateway</flowNodeRef>
        <flowNodeRef>StartEvent</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始" />
    <userTask id="AuthorityApproveProjectTask" name="批准立项" flowable:candidateGroups="AUTHORITY_OR_AGENCY" />
    <userTask id="FillContractTask" name="填写项目合同" flowable:assignee="${projectLeader}" />
    <userTask id="DeptReviewTask" name="二级单位审核" flowable:candidateGroups="DEPT_REVIEWER" />
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果" />
    <userTask id="ScienceOfficeReviewTask" name="科技处审核" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <exclusiveGateway id="ScienceOfficeReviewGateway" name="科技处审核结果" />
    <userTask id="AuthorityReviewTask" name="主管部门或专业机构审核" flowable:candidateGroups="AUTHORITY_OR_AGENCY" />
    <exclusiveGateway id="AuthorityReviewGateway" name="主管部门审核结果" />
    <userTask id="PrintPdfContractTask" name="打印PDF合同书" flowable:assignee="${projectLeader}" />
    <userTask id="LeaderSignTask" name="项目负责人签字" flowable:assignee="${projectLeader}" />
    <userTask id="SchoolSealTask" name="学校盖章" flowable:candidateGroups="SCHOOL_SEAL_ADMIN" />
    <userTask id="AuthoritySealTask" name="主管部门或专业机构盖章" flowable:candidateGroups="AUTHORITY_OR_AGENCY" />
    <userTask id="ArchiveContractTask" name="返回科技处、项目负责人存档" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <endEvent id="ApprovedEndEvent" name="合同流程完成" />
    <sequenceFlow id="Flow_Start_AuthorityApprove" sourceRef="StartEvent" targetRef="AuthorityApproveProjectTask" />
    <sequenceFlow id="Flow_AuthorityApprove_Fill" sourceRef="AuthorityApproveProjectTask" targetRef="FillContractTask" />
    <sequenceFlow id="Flow_Fill_DeptReview" sourceRef="FillContractTask" targetRef="DeptReviewTask" />
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptReviewTask" targetRef="DeptReviewGateway" />
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，返回申请人修改" sourceRef="DeptReviewGateway" targetRef="FillContractTask">
      <conditionExpression xsi:type="tFormalExpression">${deptContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptPass_ScienceReview" name="通过" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${deptContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceReview_Gateway" sourceRef="ScienceOfficeReviewTask" targetRef="ScienceOfficeReviewGateway" />
    <sequenceFlow id="Flow_ScienceReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceOfficeReviewGateway" targetRef="FillContractTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SciencePass_AuthorityReview" name="通过" sourceRef="ScienceOfficeReviewGateway" targetRef="AuthorityReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityReview_Gateway" sourceRef="AuthorityReviewTask" targetRef="AuthorityReviewGateway" />
    <sequenceFlow id="Flow_AuthorityReject_Return" name="不通过，返回申请人修改" sourceRef="AuthorityReviewGateway" targetRef="FillContractTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityPass_Print" name="通过" sourceRef="AuthorityReviewGateway" targetRef="PrintPdfContractTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Print_LeaderSign" sourceRef="PrintPdfContractTask" targetRef="LeaderSignTask" />
    <sequenceFlow id="Flow_LeaderSign_SchoolSeal" sourceRef="LeaderSignTask" targetRef="SchoolSealTask" />
    <sequenceFlow id="Flow_SchoolSeal_AuthoritySeal" sourceRef="SchoolSealTask" targetRef="AuthoritySealTask" />
    <sequenceFlow id="Flow_AuthoritySeal_Archive" sourceRef="AuthoritySealTask" targetRef="ArchiveContractTask" />
    <sequenceFlow id="Flow_Archive_End" sourceRef="ArchiveContractTask" targetRef="ApprovedEndEvent" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_researchProjectContractFillProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_researchProjectContractFillProcess" bpmnElement="researchProjectContractFillProcess">
      <bpmndi:BPMNShape id="Lane_School_di" bpmnElement="Lane_School" isHorizontal="true">
        <omgdc:Bounds x="160" y="570" width="2850" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ScienceOffice_di" bpmnElement="Lane_ScienceOffice" isHorizontal="true">
