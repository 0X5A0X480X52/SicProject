        <omgdc:Bounds x="1920" y="235" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SchoolSealTask_di" bpmnElement="SchoolSealTask">
        <omgdc:Bounds x="2120" y="595" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AuthoritySealTask_di" bpmnElement="AuthoritySealTask">
