<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/bpmn" id="Definitions_horizontalResearchProjectContractProcess" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <process id="horizontalResearchProjectContractProcess" name="横向科研项目合同书填写流程" isExecutable="true">
    <laneSet id="LaneSet_horizontalResearchProjectContractProcess">
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>StartEvent</flowNodeRef>
        <flowNodeRef>DraftEntrustContractTask</flowNodeRef>
        <flowNodeRef>UploadOaApprovalTask</flowNodeRef>
        <flowNodeRef>RegisterAndUploadPdfTask</flowNodeRef>
        <flowNodeRef>ApplyFundingAllocationTask</flowNodeRef>
        <flowNodeRef>SubmitCompletionProofTask</flowNodeRef>
        <flowNodeRef>ApprovedEndEvent</flowNodeRef>
      </lane>
      <lane id="Lane_Client" name="委托方">
        <flowNodeRef>SealBySchoolAndClientTask</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptPrincipalReviewTask</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>ScienceOfficeInitialReviewTask</flowNodeRef>
        <flowNodeRef>ScienceInitialGateway</flowNodeRef>
        <flowNodeRef>ScienceOfficeChiefReviewTask</flowNodeRef>
        <flowNodeRef>ScienceChiefGateway</flowNodeRef>
        <flowNodeRef>ScienceSystemConfirmTask</flowNodeRef>
      </lane>
      <lane id="Lane_SchoolLeader" name="校领导/OA">
        <flowNodeRef>SchoolLeaderApprovalTask</flowNodeRef>
        <flowNodeRef>SchoolLeaderGateway</flowNodeRef>
      </lane>
      <lane id="Lane_Finance" name="财务处">
        <flowNodeRef>FinanceAllocationTask</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始" />
    <userTask id="DraftEntrustContractTask" name="与委托方协商并起草项目委托合同" flowable:assignee="${projectLeader}" />
    <userTask id="UploadOaApprovalTask" name="签字并上传OA系统走审批程序" flowable:assignee="${projectLeader}" />
    <userTask id="DeptPrincipalReviewTask" name="二级单位主要负责人审核同意" flowable:candidateGroups="DEPT_PRINCIPAL" />
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果" />
    <userTask id="ScienceOfficeInitialReviewTask" name="科技处科研项目管理科初审" flowable:candidateGroups="SCIENCE_OFFICE_PROJECT_ADMIN" />
    <exclusiveGateway id="ScienceInitialGateway" name="科技处初审结果" />
    <userTask id="ScienceOfficeChiefReviewTask" name="科技处处长审核" flowable:candidateGroups="SCIENCE_OFFICE_DIRECTOR" />
    <exclusiveGateway id="ScienceChiefGateway" name="处长审核结果" />
    <userTask id="SchoolLeaderApprovalTask" name="校领导审批" flowable:candidateGroups="SCHOOL_LEADER" />
    <exclusiveGateway id="SchoolLeaderGateway" name="校领导审批结果" />
    <userTask id="SealBySchoolAndClientTask" name="学校盖章、委托方盖章" flowable:candidateGroups="SEAL_ADMIN" />
    <userTask id="RegisterAndUploadPdfTask" name="科研管理系统登记并上传签章PDF合同" flowable:assignee="${projectLeader}" />
    <userTask id="ScienceSystemConfirmTask" name="科技处科研管理系统确认" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="ApplyFundingAllocationTask" name="经费到校后OA申请经费划拨" flowable:assignee="${projectLeader}" />
    <userTask id="FinanceAllocationTask" name="财务处办理经费下拨" flowable:candidateGroups="FINANCE_ADMIN" />
    <userTask id="SubmitCompletionProofTask" name="提供委托方结题证明/结题报告/研究报告" flowable:assignee="${projectLeader}" />
    <endEvent id="ApprovedEndEvent" name="横向合同流程完成" />
    <sequenceFlow id="Flow_Start_Draft" sourceRef="StartEvent" targetRef="DraftEntrustContractTask" />
    <sequenceFlow id="Flow_Draft_UploadOA" sourceRef="DraftEntrustContractTask" targetRef="UploadOaApprovalTask" />
    <sequenceFlow id="Flow_UploadOA_DeptReview" sourceRef="UploadOaApprovalTask" targetRef="DeptPrincipalReviewTask" />
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptPrincipalReviewTask" targetRef="DeptReviewGateway" />
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，返回申请人修改" sourceRef="DeptReviewGateway" targetRef="DraftEntrustContractTask">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptPass_ScienceInitial" name="通过" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeInitialReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitial_Gateway" sourceRef="ScienceOfficeInitialReviewTask" targetRef="ScienceInitialGateway" />
    <sequenceFlow id="Flow_ScienceInitialReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceInitialGateway" targetRef="DraftEntrustContractTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitialPass_Chief" name="通过" sourceRef="ScienceInitialGateway" targetRef="ScienceOfficeChiefReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceChief_Gateway" sourceRef="ScienceOfficeChiefReviewTask" targetRef="ScienceChiefGateway" />
    <sequenceFlow id="Flow_ScienceChiefReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceChiefGateway" targetRef="DraftEntrustContractTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceChiefApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceChiefPass_School" name="通过" sourceRef="ScienceChiefGateway" targetRef="SchoolLeaderApprovalTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceChiefApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SchoolApproval_Gateway" sourceRef="SchoolLeaderApprovalTask" targetRef="SchoolLeaderGateway" />
    <sequenceFlow id="Flow_SchoolReject_Return" name="不通过，返回申请人修改" sourceRef="SchoolLeaderGateway" targetRef="DraftEntrustContractTask">
      <conditionExpression xsi:type="tFormalExpression">${schoolLeaderApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SchoolPass_Seal" name="通过" sourceRef="SchoolLeaderGateway" targetRef="SealBySchoolAndClientTask">
      <conditionExpression xsi:type="tFormalExpression">${schoolLeaderApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Seal_Register" sourceRef="SealBySchoolAndClientTask" targetRef="RegisterAndUploadPdfTask" />
    <sequenceFlow id="Flow_Register_Confirm" sourceRef="RegisterAndUploadPdfTask" targetRef="ScienceSystemConfirmTask" />
    <sequenceFlow id="Flow_Confirm_ApplyFunding" sourceRef="ScienceSystemConfirmTask" targetRef="ApplyFundingAllocationTask" />
    <sequenceFlow id="Flow_ApplyFunding_Finance" sourceRef="ApplyFundingAllocationTask" targetRef="FinanceAllocationTask" />
    <sequenceFlow id="Flow_Finance_SubmitProof" sourceRef="FinanceAllocationTask" targetRef="SubmitCompletionProofTask" />
    <sequenceFlow id="Flow_SubmitProof_End" sourceRef="SubmitCompletionProofTask" targetRef="ApprovedEndEvent" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_horizontalResearchProjectContractProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_horizontalResearchProjectContractProcess" bpmnElement="horizontalResearchProjectContractProcess">
      <bpmndi:BPMNShape id="Lane_Finance_di" bpmnElement="Lane_Finance" isHorizontal="true">
        <omgdc:Bounds x="160" y="640" width="3980" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SchoolLeader_di" bpmnElement="Lane_SchoolLeader" isHorizontal="true">
        <omgdc:Bounds x="160" y="520" width="3980" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ScienceOffice_di" bpmnElement="Lane_ScienceOffice" isHorizontal="true">
