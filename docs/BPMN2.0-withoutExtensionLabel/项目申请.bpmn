<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:flowable="http://flowable.org/bpmn" id="Definitions_ResearchProjectApply_Lanes" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <process id="researchProjectApplyProcess" name="高校科研项目申报审批流程" isExecutable="true">
    <laneSet id="LaneSet_ResearchProjectApply">
      <lane id="Lane_Authority" name="科技主管部门/第三方机构">
        <flowNodeRef>AuthorityReviewTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_Expert" name="评审专家">
        <flowNodeRef>ScienceExpertReviewTask</flowNodeRef>
        <flowNodeRef>ScienceExpertReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptReviewTask</flowNodeRef>
        <flowNodeRef>LimitProjectGateway</flowNodeRef>
        <flowNodeRef>DeptExpertReviewTask</flowNodeRef>
        <flowNodeRef>DeptExpertReviewGateway</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>SubmitApplicationTask</flowNodeRef>
        <flowNodeRef>SignAndSealTask</flowNodeRef>
      </lane>
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>StartEvent</flowNodeRef>
        <flowNodeRef>PublishNoticeTask</flowNodeRef>
        <flowNodeRef>ScienceOfficePublicityTask</flowNodeRef>
        <flowNodeRef>SubmitFinalMaterialsTask</flowNodeRef>
        <flowNodeRef>ApprovedEndEvent</flowNodeRef>
        <flowNodeRef>ScienceOfficeInitialReviewTask</flowNodeRef>
        <flowNodeRef>ScienceOfficeSubmitTask</flowNodeRef>
        <flowNodeRef>ScienceOfficePublicityGateway</flowNodeRef>
        <flowNodeRef>ScienceOfficeInitialGateway</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始" />
    <userTask id="PublishNoticeTask" name="发布申报通知" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="SubmitApplicationTask" name="填报并提交项目申请书" flowable:assignee="${projectLeader}" />
    <userTask id="DeptReviewTask" name="二级单位形式审核" flowable:candidateGroups="DEPT_REVIEWER" />
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果" />
    <exclusiveGateway id="LimitProjectGateway" name="是否限项项目" />
    <userTask id="DeptExpertReviewTask" name="二级单位专家评审并择优推荐" flowable:candidateGroups="DEPT_EXPERT" />
    <exclusiveGateway id="DeptExpertReviewGateway" name="院级专家评审结果" />
    <userTask id="ScienceOfficeInitialReviewTask" name="科技处初审" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <exclusiveGateway id="ScienceOfficeInitialGateway" name="科技处初审结果" />
    <userTask id="ScienceExpertReviewTask" name="科技处组织专家评审" flowable:candidateGroups="PROJECT_EXPERT" />
    <exclusiveGateway id="ScienceExpertReviewGateway" name="专家评审结果" />
    <userTask id="ScienceOfficePublicityTask" name="科技处择优推荐并公示" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <exclusiveGateway id="ScienceOfficePublicityGateway" name="公示结果" />
    <userTask id="ScienceOfficeSubmitTask" name="科技处审核上报" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="AuthorityReviewTask" name="主管部门或第三方机构审核结果登记" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <exclusiveGateway id="AuthorityReviewGateway" name="主管部门审核结果" />
    <userTask id="SignAndSealTask" name="打印申请书、签字并申请用章" flowable:assignee="${projectLeader}" />
    <userTask id="SubmitFinalMaterialsTask" name="报送主管部门或第三方机构" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <endEvent id="ApprovedEndEvent" name="申报流程完成" />
    <sequenceFlow id="Flow_Start_Publish" sourceRef="StartEvent" targetRef="PublishNoticeTask" />
    <sequenceFlow id="Flow_Publish_Submit" sourceRef="PublishNoticeTask" targetRef="SubmitApplicationTask" />
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，退回修改" sourceRef="DeptReviewGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptExpertReject_Return" name="不通过，退回修改" sourceRef="DeptExpertReviewGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${deptExpertApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitialReject_Return" name="不通过，退回修改" sourceRef="ScienceOfficeInitialGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceExpertReject_Return" name="不通过，退回修改" sourceRef="ScienceExpertReviewGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceExpertApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_PublicityReject_Return" name="不通过，退回修改" sourceRef="ScienceOfficePublicityGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${publicityApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityReject_Return" name="不通过，退回修改" sourceRef="AuthorityReviewGateway" targetRef="SubmitApplicationTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Submit_DeptReview" sourceRef="SubmitApplicationTask" targetRef="DeptReviewTask" />
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptReviewTask" targetRef="DeptReviewGateway" />
    <sequenceFlow id="Flow_DeptPass_LimitGateway" name="通过" sourceRef="DeptReviewGateway" targetRef="LimitProjectGateway">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Limited_DeptExpert" name="限项项目" sourceRef="LimitProjectGateway" targetRef="DeptExpertReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${isLimitedProject == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_NonLimited_ScienceInitial" name="非限项项目" sourceRef="LimitProjectGateway" targetRef="ScienceOfficeInitialReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${isLimitedProject == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptExpert_Gateway" sourceRef="DeptExpertReviewTask" targetRef="DeptExpertReviewGateway" />
    <sequenceFlow id="Flow_DeptExpertPass_ScienceInitial" name="通过" sourceRef="DeptExpertReviewGateway" targetRef="ScienceOfficeInitialReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${deptExpertApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitial_Gateway" sourceRef="ScienceOfficeInitialReviewTask" targetRef="ScienceOfficeInitialGateway" />
    <sequenceFlow id="Flow_ScienceInitialPass_ExpertReview" name="通过" sourceRef="ScienceOfficeInitialGateway" targetRef="ScienceExpertReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceExpert_Gateway" sourceRef="ScienceExpertReviewTask" targetRef="ScienceExpertReviewGateway" />
    <sequenceFlow id="Flow_ScienceExpertPass_Publicity" name="通过" sourceRef="ScienceExpertReviewGateway" targetRef="ScienceOfficePublicityTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceExpertApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Publicity_Gateway" sourceRef="ScienceOfficePublicityTask" targetRef="ScienceOfficePublicityGateway" />
    <sequenceFlow id="Flow_PublicityPass_Submit" name="通过" sourceRef="ScienceOfficePublicityGateway" targetRef="ScienceOfficeSubmitTask">
      <conditionExpression xsi:type="tFormalExpression">${publicityApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceSubmit_AuthorityReview" sourceRef="ScienceOfficeSubmitTask" targetRef="AuthorityReviewTask" />
    <sequenceFlow id="Flow_AuthorityReview_Gateway" sourceRef="AuthorityReviewTask" targetRef="AuthorityReviewGateway" />
    <sequenceFlow id="Flow_AuthorityPass_SignSeal" name="通过" sourceRef="AuthorityReviewGateway" targetRef="SignAndSealTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SignSeal_SubmitFinal" sourceRef="SignAndSealTask" targetRef="SubmitFinalMaterialsTask" />
    <sequenceFlow id="Flow_SubmitFinal_End" sourceRef="SubmitFinalMaterialsTask" targetRef="ApprovedEndEvent" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ResearchProjectApply_Lanes">
    <bpmndi:BPMNPlane id="BPMNPlane_ResearchProjectApply_Lanes" bpmnElement="researchProjectApplyProcess">
