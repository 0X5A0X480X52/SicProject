<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/bpmn" id="Definitions_researchProjectAcceptanceProcess" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <process id="researchProjectAcceptanceProcess" name="科研项目结题验收流程" isExecutable="true">
    <laneSet id="LaneSet_researchProjectAcceptanceProcess">
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>StartEvent</flowNodeRef>
        <flowNodeRef>PublishAcceptanceNoticeTask</flowNodeRef>
        <flowNodeRef>ScienceOfficeReviewTask</flowNodeRef>
        <flowNodeRef>ScienceOfficeReviewGateway</flowNodeRef>
        <flowNodeRef>ProjectTypeGateway</flowNodeRef>
        <flowNodeRef>SubmitFinalMaterialsTask</flowNodeRef>
        <flowNodeRef>IssueCertificateTask</flowNodeRef>
        <flowNodeRef>IssueFailFileTask</flowNodeRef>
        <flowNodeRef>AcceptedEndEvent</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptNotifyLeaderTask</flowNodeRef>
        <flowNodeRef>DeptReviewTask</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>SubmitAcceptanceMaterialsTask</flowNodeRef>
        <flowNodeRef>SignSealAcceptanceTask</flowNodeRef>
      </lane>
      <lane id="Lane_Finance" name="财务处">
        <flowNodeRef>FinancialSettlementTask</flowNodeRef>
        <flowNodeRef>ReturnSurplusFundsTask</flowNodeRef>
        <flowNodeRef>RejectedEndEvent</flowNodeRef>
      </lane>
      <lane id="Lane_Authority" name="科技主管部门/第三方机构">
        <flowNodeRef>AuthorityReviewTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_Expert" name="评审专家">
        <flowNodeRef>ExpertReviewTask</flowNodeRef>
        <flowNodeRef>ExpertReviewGateway</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始" />
    <userTask id="PublishAcceptanceNoticeTask" name="发布结题验收通知" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="DeptNotifyLeaderTask" name="通知项目负责人" flowable:candidateGroups="DEPT_REVIEWER" />
    <userTask id="FinancialSettlementTask" name="办理经费决算并打印报销清单" flowable:candidateGroups="FINANCE_ADMIN" />
    <userTask id="SubmitAcceptanceMaterialsTask" name="填报结题验收材料" flowable:assignee="${projectLeader}" />
    <userTask id="DeptReviewTask" name="二级单位审核" flowable:candidateGroups="DEPT_REVIEWER" />
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果" />
    <userTask id="ScienceOfficeReviewTask" name="科技处审核" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <exclusiveGateway id="ScienceOfficeReviewGateway" name="科技处审核结果" />
    <exclusiveGateway id="ProjectTypeGateway" name="是否校级项目结题验收" />
    <userTask id="AuthorityReviewTask" name="主管部门或第三方机构审核" flowable:candidateGroups="AUTHORITY_OR_AGENCY" />
    <exclusiveGateway id="AuthorityReviewGateway" name="主管部门审核结果" />
    <userTask id="SignSealAcceptanceTask" name="打印结题材料签字并申请用章" flowable:assignee="${projectLeader}" />
    <userTask id="SubmitFinalMaterialsTask" name="报送主管部门或第三方机构" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="ExpertReviewTask" name="专家评审" flowable:candidateGroups="PROJECT_EXPERT" />
    <exclusiveGateway id="ExpertReviewGateway" name="专家评审结果" />
    <userTask id="IssueCertificateTask" name="发放验收证书或下达结题通过文件" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="IssueFailFileTask" name="下达结题不通过文件" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN" />
    <userTask id="ReturnSurplusFundsTask" name="退还结余经费" flowable:candidateGroups="FINANCE_ADMIN" />
    <endEvent id="AcceptedEndEvent" name="结题验收通过" />
    <endEvent id="RejectedEndEvent" name="结题未通过结束" />
    <sequenceFlow id="Flow_Start_Publish" sourceRef="StartEvent" targetRef="PublishAcceptanceNoticeTask" />
    <sequenceFlow id="Flow_Publish_DeptNotify" sourceRef="PublishAcceptanceNoticeTask" targetRef="DeptNotifyLeaderTask" />
    <sequenceFlow id="Flow_DeptNotify_Financial" sourceRef="DeptNotifyLeaderTask" targetRef="FinancialSettlementTask" />
    <sequenceFlow id="Flow_Financial_Submit" sourceRef="FinancialSettlementTask" targetRef="SubmitAcceptanceMaterialsTask" />
    <sequenceFlow id="Flow_Submit_DeptReview" sourceRef="SubmitAcceptanceMaterialsTask" targetRef="DeptReviewTask" />
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptReviewTask" targetRef="DeptReviewGateway" />
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，返回申请人修改" sourceRef="DeptReviewGateway" targetRef="SubmitAcceptanceMaterialsTask">
      <conditionExpression xsi:type="tFormalExpression">${deptAcceptanceApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptPass_ScienceReview" name="通过" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${deptAcceptanceApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceReview_Gateway" sourceRef="ScienceOfficeReviewTask" targetRef="ScienceOfficeReviewGateway" />
    <sequenceFlow id="Flow_ScienceReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceOfficeReviewGateway" targetRef="SubmitAcceptanceMaterialsTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceAcceptanceApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SciencePass_ProjectType" name="通过" sourceRef="ScienceOfficeReviewGateway" targetRef="ProjectTypeGateway">
      <conditionExpression xsi:type="tFormalExpression">${scienceAcceptanceApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SchoolLevel_Expert" name="校级项目结题验收" sourceRef="ProjectTypeGateway" targetRef="ExpertReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${isSchoolLevelAcceptance == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_NonSchool_AuthorityReview" name="非校级项目" sourceRef="ProjectTypeGateway" targetRef="AuthorityReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${isSchoolLevelAcceptance == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityReview_Gateway" sourceRef="AuthorityReviewTask" targetRef="AuthorityReviewGateway" />
    <sequenceFlow id="Flow_AuthorityReject_Return" name="不通过，返回申请人修改" sourceRef="AuthorityReviewGateway" targetRef="SubmitAcceptanceMaterialsTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityAcceptanceApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityPass_SignSeal" name="通过" sourceRef="AuthorityReviewGateway" targetRef="SignSealAcceptanceTask">
      <conditionExpression xsi:type="tFormalExpression">${authorityAcceptanceApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SignSeal_SubmitFinal" sourceRef="SignSealAcceptanceTask" targetRef="SubmitFinalMaterialsTask" />
    <sequenceFlow id="Flow_SubmitFinal_Expert" sourceRef="SubmitFinalMaterialsTask" targetRef="ExpertReviewTask" />
    <sequenceFlow id="Flow_ExpertReview_Gateway" sourceRef="ExpertReviewTask" targetRef="ExpertReviewGateway" />
    <sequenceFlow id="Flow_ExpertPass_IssueCertificate" name="通过" sourceRef="ExpertReviewGateway" targetRef="IssueCertificateTask">
      <conditionExpression xsi:type="tFormalExpression">${expertAcceptanceApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ExpertReject_IssueFail" name="不通过" sourceRef="ExpertReviewGateway" targetRef="IssueFailFileTask">
      <conditionExpression xsi:type="tFormalExpression">${expertAcceptanceApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_IssueCertificate_End" sourceRef="IssueCertificateTask" targetRef="AcceptedEndEvent" />
    <sequenceFlow id="Flow_IssueFail_ReturnFunds" sourceRef="IssueFailFileTask" targetRef="ReturnSurplusFundsTask" />
    <sequenceFlow id="Flow_ReturnFunds_RejectedEnd" sourceRef="ReturnSurplusFundsTask" targetRef="RejectedEndEvent" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_researchProjectAcceptanceProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_researchProjectAcceptanceProcess" bpmnElement="researchProjectAcceptanceProcess">
