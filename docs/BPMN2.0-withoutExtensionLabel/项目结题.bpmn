      <bpmndi:BPMNEdge id="Flow_ExpertPass_IssueCertificate_di" bpmnElement="Flow_ExpertPass_IssueCertificate">
        <omgdi:waypoint x="3205" y="895" />
        <omgdi:waypoint x="3205" y="87" />
