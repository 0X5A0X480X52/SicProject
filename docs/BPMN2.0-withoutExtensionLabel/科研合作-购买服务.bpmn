<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/bpmn" id="Definitions_researchCooperationPurchaseServiceApprovalProcess" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <process id="researchCooperationPurchaseServiceApprovalProcess" name="科研合作协议、购买服务合同审批流程" isExecutable="true">
    <laneSet id="LaneSet_researchCooperationPurchaseServiceApprovalProcess">
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>StartEvent</flowNodeRef>
        <flowNodeRef>DraftContractTemplateTask</flowNodeRef>
        <flowNodeRef>UploadOaApprovalTask</flowNodeRef>
        <flowNodeRef>PurchaseServiceEndEvent</flowNodeRef>
        <flowNodeRef>SavePurchaseCopiesTask</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptPrincipalReviewTask</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>ScienceOfficeInitialReviewTask</flowNodeRef>
        <flowNodeRef>ScienceInitialGateway</flowNodeRef>
        <flowNodeRef>ScienceOfficeChiefReviewTask</flowNodeRef>
        <flowNodeRef>ScienceChiefGateway</flowNodeRef>
        <flowNodeRef>CooperationEndEvent</flowNodeRef>
        <flowNodeRef>SaveCooperationCopiesTask</flowNodeRef>
      </lane>
      <lane id="Lane_SchoolLeader" name="校领导/OA">
        <flowNodeRef>SchoolLeaderApprovalTask</flowNodeRef>
        <flowNodeRef>SchoolLeaderGateway</flowNodeRef>
      </lane>
      <lane id="Lane_Finance" name="财务处">
        <flowNodeRef>FinanceTransferTask</flowNodeRef>
      </lane>
      <lane id="Lane_Counterparty" name="合作方/被委托单位">
        <flowNodeRef>SealTask</flowNodeRef>
        <flowNodeRef>ContractTypeGateway</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始" />
    <userTask id="DraftContractTemplateTask" name="按学校合同范本起草合同" flowable:assignee="${projectLeader}" />
    <userTask id="UploadOaApprovalTask" name="签字并上传OA系统走审批程序" flowable:assignee="${projectLeader}" />
    <userTask id="DeptPrincipalReviewTask" name="二级单位主要负责人审核同意" flowable:candidateGroups="DEPT_PRINCIPAL" />
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果" />
    <userTask id="ScienceOfficeInitialReviewTask" name="科技处科研项目管理科初审" flowable:candidateGroups="SCIENCE_OFFICE_PROJECT_ADMIN" />
    <exclusiveGateway id="ScienceInitialGateway" name="科技处初审结果" />
    <userTask id="ScienceOfficeChiefReviewTask" name="科技处处长审核" flowable:candidateGroups="SCIENCE_OFFICE_DIRECTOR" />
    <exclusiveGateway id="ScienceChiefGateway" name="处长审核结果" />
    <userTask id="SchoolLeaderApprovalTask" name="校领导审批" flowable:candidateGroups="SCHOOL_LEADER" />
    <exclusiveGateway id="SchoolLeaderGateway" name="校领导审批结果" />
    <userTask id="SealTask" name="委托代理人、学校盖章、委托方盖章" flowable:candidateGroups="SEAL_ADMIN" />
    <exclusiveGateway id="ContractTypeGateway" name="合同类型">
      <outgoing>Flow_Type_Cooperation</outgoing>
    </exclusiveGateway>
    <userTask id="SaveCooperationCopiesTask" name="科技处、项目负责人、合作方各保存1份" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN">
      <incoming>Flow_Type_Cooperation</incoming>
    </userTask>
    <userTask id="FinanceTransferTask" name="财务处转拨经费" flowable:candidateGroups="FINANCE_ADMIN" />
    <userTask id="SavePurchaseCopiesTask" name="项目负责人、被委托单位各保存2份" flowable:assignee="${projectLeader}" />
    <endEvent id="CooperationEndEvent" name="科研合作流程完成" />
    <endEvent id="PurchaseServiceEndEvent" name="购买服务流程完成" />
    <sequenceFlow id="Flow_Start_Draft" sourceRef="StartEvent" targetRef="DraftContractTemplateTask" />
    <sequenceFlow id="Flow_Draft_UploadOA" sourceRef="DraftContractTemplateTask" targetRef="UploadOaApprovalTask" />
    <sequenceFlow id="Flow_UploadOA_DeptReview" sourceRef="UploadOaApprovalTask" targetRef="DeptPrincipalReviewTask" />
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptPrincipalReviewTask" targetRef="DeptReviewGateway" />
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，返回申请人修改" sourceRef="DeptReviewGateway" targetRef="DraftContractTemplateTask">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptPass_ScienceInitial" name="通过" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeInitialReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${deptApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitial_Gateway" sourceRef="ScienceOfficeInitialReviewTask" targetRef="ScienceInitialGateway" />
    <sequenceFlow id="Flow_ScienceInitialReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceInitialGateway" targetRef="DraftContractTemplateTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceInitialPass_Chief" name="通过" sourceRef="ScienceInitialGateway" targetRef="ScienceOfficeChiefReviewTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceInitialApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceChief_Gateway" sourceRef="ScienceOfficeChiefReviewTask" targetRef="ScienceChiefGateway" />
    <sequenceFlow id="Flow_ScienceChiefReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceChiefGateway" targetRef="DraftContractTemplateTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceChiefApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceChiefPass_School" name="通过" sourceRef="ScienceChiefGateway" targetRef="SchoolLeaderApprovalTask">
      <conditionExpression xsi:type="tFormalExpression">${scienceChiefApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SchoolApproval_Gateway" sourceRef="SchoolLeaderApprovalTask" targetRef="SchoolLeaderGateway" />
    <sequenceFlow id="Flow_SchoolReject_Return" name="不通过，返回申请人修改" sourceRef="SchoolLeaderGateway" targetRef="DraftContractTemplateTask">
      <conditionExpression xsi:type="tFormalExpression">${schoolLeaderApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SchoolPass_Seal" name="通过" sourceRef="SchoolLeaderGateway" targetRef="SealTask">
      <conditionExpression xsi:type="tFormalExpression">${schoolLeaderApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Seal_ContractType" sourceRef="SealTask" targetRef="ContractTypeGateway" />
    <sequenceFlow id="Flow_Type_PurchaseService" name="购买服务" sourceRef="ContractTypeGateway" targetRef="FinanceTransferTask">
      <conditionExpression xsi:type="tFormalExpression">${contractType == "purchaseService"}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Finance_SavePurchase" sourceRef="FinanceTransferTask" targetRef="SavePurchaseCopiesTask" />
    <sequenceFlow id="Flow_SaveCooperation_End" sourceRef="SaveCooperationCopiesTask" targetRef="CooperationEndEvent" />
    <sequenceFlow id="Flow_SavePurchase_End" sourceRef="SavePurchaseCopiesTask" targetRef="PurchaseServiceEndEvent" />
    <sequenceFlow id="Flow_Type_Cooperation" name="科研合作" sourceRef="ContractTypeGateway" targetRef="SaveCooperationCopiesTask">
      <conditionExpression xsi:type="tFormalExpression">${contractType == "cooperation"}</conditionExpression>
    </sequenceFlow>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_researchCooperationPurchaseServiceApprovalProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_researchCooperationPurchaseServiceApprovalProcess" bpmnElement="researchCooperationPurchaseServiceApprovalProcess">
      <bpmndi:BPMNShape id="Lane_Counterparty_di" bpmnElement="Lane_Counterparty" isHorizontal="true">
        <omgdc:Bounds x="160" y="640" width="3400" height="120" />
