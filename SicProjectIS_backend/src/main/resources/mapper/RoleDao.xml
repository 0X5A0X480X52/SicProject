<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.amatrix.sicprojectis_backend.dao.RoleDao">
    <resultMap id="BaseResultMap" type="com.amatrix.sicprojectis_backend.entity.Role">
        <id column="role_id" property="roleId" jdbcType="BIGINT" />
        <result column="role_code" property="roleCode" jdbcType="VARCHAR" />
        <result column="role_name" property="roleName" jdbcType="VARCHAR" />
        <result column="role_desc" property="roleDesc" jdbcType="LONGVARCHAR" />
        <result column="enabled" property="enabled" jdbcType="TINYINT" />
    </resultMap>

    <sql id="BaseColumnList">`role_id`, `role_code`, `role_name`, `role_desc`, `enabled`</sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `role` WHERE `role_id` = #{roleId, jdbcType=BIGINT}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `role`
    </select>

    <insert id="insert" parameterType="com.amatrix.sicprojectis_backend.entity.Role" useGeneratedKeys="true" keyProperty="roleId" keyColumn="role_id">
        INSERT INTO `role` (
            `role_code`, `role_name`, `role_desc`, `enabled`
        ) VALUES (
            #{roleCode, jdbcType=VARCHAR}, #{roleName, jdbcType=VARCHAR}, #{roleDesc, jdbcType=LONGVARCHAR}, #{enabled, jdbcType=TINYINT}
        )
    </insert>

    <update id="updateById" parameterType="com.amatrix.sicprojectis_backend.entity.Role">
        UPDATE `role`
        SET
            `role_code` = #{roleCode, jdbcType=VARCHAR},
            `role_name` = #{roleName, jdbcType=VARCHAR},
            `role_desc` = #{roleDesc, jdbcType=LONGVARCHAR},
            `enabled` = #{enabled, jdbcType=TINYINT}
        WHERE `role_id` = #{roleId, jdbcType=BIGINT}
    </update>

    <delete id="deleteById">
        DELETE FROM `role` WHERE `role_id` = #{roleId, jdbcType=BIGINT}
    </delete>
</mapper>
