<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.amatrix.sicprojectis_backend.material.dao.MaterialVersionDao">
    <resultMap id="BaseResultMap" type="com.amatrix.sicprojectis_backend.material.entity.MaterialVersion">
        <id column="material_version_id" property="materialVersionId" jdbcType="BIGINT" />
        <result column="material_id" property="materialId" jdbcType="BIGINT" />
        <result column="version_no" property="versionNo" jdbcType="INTEGER" />
        <result column="file_name" property="fileName" jdbcType="VARCHAR" />
        <result column="file_url" property="fileUrl" jdbcType="VARCHAR" />
        <result column="file_hash" property="fileHash" jdbcType="VARCHAR" />
        <result column="uploaded_by" property="uploadedBy" jdbcType="BIGINT" />
        <result column="uploaded_at" property="uploadedAt" jdbcType="TIMESTAMP" />
        <result column="is_current" property="isCurrent" jdbcType="TINYINT" />
    </resultMap>

    <sql id="BaseColumnList">`material_version_id`, `material_id`, `version_no`, `file_name`, `file_url`, `file_hash`, `uploaded_by`, `uploaded_at`, `is_current`</sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material_version` WHERE `material_version_id` = #{materialVersionId, jdbcType=BIGINT}
    </select>

    <select id="selectByMaterialId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material_version`
        WHERE `material_id` = #{materialId, jdbcType=BIGINT}
        ORDER BY `version_no`
    </select>

    <select id="selectLatestByMaterialId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material_version`
        WHERE `material_id` = #{materialId, jdbcType=BIGINT}
        ORDER BY `version_no` DESC
        LIMIT 1
    </select>

    <update id="clearCurrentByMaterialId">
        UPDATE `material_version`
        SET `is_current` = 0
        WHERE `material_id` = #{materialId, jdbcType=BIGINT}
    </update>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material_version`
    </select>

    <insert id="insert" parameterType="com.amatrix.sicprojectis_backend.material.entity.MaterialVersion" useGeneratedKeys="true" keyProperty="materialVersionId" keyColumn="material_version_id">
        INSERT INTO `material_version` (
            `material_id`, `version_no`, `file_name`, `file_url`, `file_hash`, `uploaded_by`, `is_current`
        ) VALUES (
            #{materialId, jdbcType=BIGINT}, #{versionNo, jdbcType=INTEGER}, #{fileName, jdbcType=VARCHAR}, #{fileUrl, jdbcType=VARCHAR}, #{fileHash, jdbcType=VARCHAR}, #{uploadedBy, jdbcType=BIGINT}, #{isCurrent, jdbcType=TINYINT}
        )
    </insert>

    <update id="updateById" parameterType="com.amatrix.sicprojectis_backend.material.entity.MaterialVersion">
        UPDATE `material_version`
        SET
            `material_id` = #{materialId, jdbcType=BIGINT},
            `version_no` = #{versionNo, jdbcType=INTEGER},
            `file_name` = #{fileName, jdbcType=VARCHAR},
            `file_url` = #{fileUrl, jdbcType=VARCHAR},
            `file_hash` = #{fileHash, jdbcType=VARCHAR},
            `uploaded_by` = #{uploadedBy, jdbcType=BIGINT},
            `is_current` = #{isCurrent, jdbcType=TINYINT}
        WHERE `material_version_id` = #{materialVersionId, jdbcType=BIGINT}
    </update>

    <delete id="deleteById">
        DELETE FROM `material_version` WHERE `material_version_id` = #{materialVersionId, jdbcType=BIGINT}
    </delete>
</mapper>
