<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.amatrix.sicprojectis_backend.dao.UserRoleDetailViewDao">
    <resultMap id="BaseResultMap" type="com.amatrix.sicprojectis_backend.entity.UserRoleDetailView">
        <id column="user_id" property="userId" jdbcType="BIGINT" />
        <result column="username" property="username" jdbcType="VARCHAR" />
        <result column="real_name" property="realName" jdbcType="VARCHAR" />
        <result column="dept_id" property="deptId" jdbcType="BIGINT" />
        <result column="dept_name" property="deptName" jdbcType="VARCHAR" />
        <result column="role_id" property="roleId" jdbcType="BIGINT" />
        <result column="role_code" property="roleCode" jdbcType="VARCHAR" />
        <result column="role_name" property="roleName" jdbcType="VARCHAR" />
    </resultMap>

    <sql id="BaseColumnList">`user_id`, `username`, `real_name`, `dept_id`, `dept_name`, `role_id`, `role_code`, `role_name`</sql>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `v_user_role_detail` WHERE `user_id` = #{userId, jdbcType=BIGINT}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `v_user_role_detail`
    </select>
</mapper>
