<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.amatrix.sicprojectis_backend.dao.MaterialDao">
    <resultMap id="BaseResultMap" type="com.amatrix.sicprojectis_backend.entity.Material">
        <id column="material_id" property="materialId" jdbcType="BIGINT" />
        <result column="project_id" property="projectId" jdbcType="BIGINT" />
        <result column="material_type_id" property="materialTypeId" jdbcType="BIGINT" />
        <result column="created_by" property="createdBy" jdbcType="BIGINT" />
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP" />
    </resultMap>

    <sql id="BaseColumnList">`material_id`, `project_id`, `material_type_id`, `created_by`, `created_at`</sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material` WHERE `material_id` = #{materialId, jdbcType=BIGINT}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `material`
    </select>

    <insert id="insert" parameterType="com.amatrix.sicprojectis_backend.entity.Material" useGeneratedKeys="true" keyProperty="materialId" keyColumn="material_id">
        INSERT INTO `material` (
            `project_id`, `material_type_id`, `created_by`
        ) VALUES (
            #{projectId, jdbcType=BIGINT}, #{materialTypeId, jdbcType=BIGINT}, #{createdBy, jdbcType=BIGINT}
        )
    </insert>

    <update id="updateById" parameterType="com.amatrix.sicprojectis_backend.entity.Material">
        UPDATE `material`
        SET
            `project_id` = #{projectId, jdbcType=BIGINT},
            `material_type_id` = #{materialTypeId, jdbcType=BIGINT},
            `created_by` = #{createdBy, jdbcType=BIGINT}
        WHERE `material_id` = #{materialId, jdbcType=BIGINT}
    </update>

    <delete id="deleteById">
        DELETE FROM `material` WHERE `material_id` = #{materialId, jdbcType=BIGINT}
    </delete>
</mapper>
