<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.amatrix.sicprojectis_backend.dao.DepartmentDao">
    <resultMap id="BaseResultMap" type="com.amatrix.sicprojectis_backend.entity.Department">
        <id column="dept_id" property="deptId" jdbcType="BIGINT" />
        <result column="dept_code" property="deptCode" jdbcType="VARCHAR" />
        <result column="dept_name" property="deptName" jdbcType="VARCHAR" />
        <result column="parent_dept_id" property="parentDeptId" jdbcType="BIGINT" />
        <result column="enabled" property="enabled" jdbcType="TINYINT" />
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP" />
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP" />
    </resultMap>

    <sql id="BaseColumnList">`dept_id`, `dept_code`, `dept_name`, `parent_dept_id`, `enabled`, `created_at`, `updated_at`</sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `department` WHERE `dept_id` = #{deptId, jdbcType=BIGINT}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumnList" /> FROM `department`
    </select>

    <insert id="insert" parameterType="com.amatrix.sicprojectis_backend.entity.Department" useGeneratedKeys="true" keyProperty="deptId" keyColumn="dept_id">
        INSERT INTO `department` (
            `dept_code`, `dept_name`, `parent_dept_id`, `enabled`
        ) VALUES (
            #{deptCode, jdbcType=VARCHAR}, #{deptName, jdbcType=VARCHAR}, #{parentDeptId, jdbcType=BIGINT}, #{enabled, jdbcType=TINYINT}
        )
    </insert>

    <update id="updateById" parameterType="com.amatrix.sicprojectis_backend.entity.Department">
        UPDATE `department`
        SET
            `dept_code` = #{deptCode, jdbcType=VARCHAR},
            `dept_name` = #{deptName, jdbcType=VARCHAR},
            `parent_dept_id` = #{parentDeptId, jdbcType=BIGINT},
            `enabled` = #{enabled, jdbcType=TINYINT}
        WHERE `dept_id` = #{deptId, jdbcType=BIGINT}
    </update>

    <delete id="deleteById">
        DELETE FROM `department` WHERE `dept_id` = #{deptId, jdbcType=BIGINT}
    </delete>
</mapper>
