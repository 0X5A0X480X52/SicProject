<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:flowable="http://flowable.org/bpmn" xmlns:rm="http://example.com/research-management" id="Definitions_researchProjectContractFillProcess" targetNamespace="http://www.example.com/research-project" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2"><process id="researchProjectContractFillProcess" name="科研项目合同书填写流程" isExecutable="true">
    <extensionElements><rm:processConfig processKey="CONTRACT_PROCESS" moduleType="CONTRACT" versionNo="1" status="ACTIVE" currentStateView="v_module_runtime_context" runtimeContextView="v_module_runtime_context" taskTable="task_instance" stateRecordTable="module_state_record" remarkTable="state_record_remark" materialLinkTable="state_record_material" sseEventType="MODULE_STATE_CHANGED" viewModelRefreshMode="RELOAD_AFTER_SSE"/></extensionElements><laneSet id="LaneSet_researchProjectContractFillProcess">
      <lane id="Lane_School" name="学校">
        <flowNodeRef>SchoolSealTask</flowNodeRef>
      </lane>
      <lane id="Lane_ScienceOffice" name="科技处">
        <flowNodeRef>ScienceOfficeReviewTask</flowNodeRef>
        <flowNodeRef>ArchiveContractTask</flowNodeRef>
        <flowNodeRef>ScienceOfficeReviewGateway</flowNodeRef>
        <flowNodeRef>ApprovedEndEvent</flowNodeRef>
      </lane>
      <lane id="Lane_Department" name="二级单位">
        <flowNodeRef>DeptReviewTask</flowNodeRef>
        <flowNodeRef>DeptReviewGateway</flowNodeRef>
      </lane>
      <lane id="Lane_ProjectLeader" name="项目负责人">
        <flowNodeRef>FillContractTask</flowNodeRef>
        <flowNodeRef>PrintPdfContractTask</flowNodeRef>
        <flowNodeRef>LeaderSignTask</flowNodeRef>
      </lane>
      <lane id="Lane_Authority" name="科技主管部门/专业机构">
        <flowNodeRef>AuthorityApproveProjectTask</flowNodeRef>
        <flowNodeRef>AuthoritySealTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewTask</flowNodeRef>
        <flowNodeRef>AuthorityReviewGateway</flowNodeRef>
        <flowNodeRef>StartEvent</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent" name="开始"><extensionElements><rm:workflowNode stateCode="CONTRACT_START" nodeType="START_EVENT" laneName="科技主管部门/专业机构" responsibleActorCode="SYSTEM" responsibleActorName="系统" operationMode="SYSTEM_AUTO" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/></extensionElements></startEvent>
    <userTask id="AuthorityApproveProjectTask" name="批准立项" flowable:candidateGroups="AUTHORITY_OR_AGENCY"><extensionElements><rm:workflowNode stateCode="CONTRACT_PROJECT_APPROVED" nodeType="USER_TASK" laneName="科技主管部门/专业机构" responsibleActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" responsibleActorName="科技主管部门/专业机构" candidateRoleCode="SCIENCE_ADMIN" operationMode="PROXY_INPUT" representedActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" representedActorName="科技主管部门/专业机构" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="PROJECT_APPROVAL_FILE" materialTypeName="项目立项批复文件" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="PROOF_FILE" allowedFileTypes="pdf,jpg,png" maxFileSizeMb="20"/></extensionElements></userTask>
    <userTask id="FillContractTask" name="填写项目合同" flowable:assignee="${projectLeader}"><extensionElements><rm:workflowNode stateCode="CONTRACT_DRAFT" nodeType="USER_TASK" laneName="项目负责人" responsibleActorCode="PROJECT_LEADER" responsibleActorName="项目负责人" candidateRoleCode="PROJECT_LEADER" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="CONTRACT_DRAFT" materialTypeName="项目合同书草稿" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="SUBMITTED_FILE" allowedFileTypes="pdf,doc,docx" maxFileSizeMb="50"/></extensionElements></userTask>
    <userTask id="DeptReviewTask" name="二级单位审核" flowable:candidateGroups="DEPT_REVIEWER"><extensionElements><rm:workflowNode stateCode="CONTRACT_DEPT_REVIEWING" nodeType="USER_TASK" laneName="二级单位" responsibleActorCode="DEPARTMENT" responsibleActorName="二级单位" candidateRoleCode="DEPT_ADMIN" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="DEPT_CONTRACT_REVIEW_OPINION" materialTypeName="二级单位合同审核意见" requirementTiming="BEFORE_SUBMIT" required="false" minCount="0" usageType="REVIEW_ATTACHMENT" allowedFileTypes="pdf,doc,docx,jpg,png" maxFileSizeMb="20"/></extensionElements></userTask>
    <exclusiveGateway id="DeptReviewGateway" name="二级单位审核结果"><extensionElements><rm:workflowNode nodeType="GATEWAY" laneName="二级单位" responsibleActorCode="SYSTEM" responsibleActorName="系统" operationMode="SYSTEM_AUTO" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/></extensionElements></exclusiveGateway>
    <userTask id="ScienceOfficeReviewTask" name="科技处审核" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN"><extensionElements><rm:workflowNode stateCode="CONTRACT_SCIENCE_REVIEWING" nodeType="USER_TASK" laneName="科技处" responsibleActorCode="SCIENCE_OFFICE" responsibleActorName="科技处" candidateRoleCode="SCIENCE_ADMIN" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="SCIENCE_CONTRACT_REVIEW_OPINION" materialTypeName="科技处合同审核意见" requirementTiming="BEFORE_SUBMIT" required="false" minCount="0" usageType="REVIEW_ATTACHMENT" allowedFileTypes="pdf,doc,docx,jpg,png" maxFileSizeMb="20"/></extensionElements></userTask>
    <exclusiveGateway id="ScienceOfficeReviewGateway" name="科技处审核结果"><extensionElements><rm:workflowNode nodeType="GATEWAY" laneName="科技处" responsibleActorCode="SYSTEM" responsibleActorName="系统" operationMode="SYSTEM_AUTO" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/></extensionElements></exclusiveGateway>
    <userTask id="AuthorityReviewTask" name="主管部门或专业机构审核" flowable:candidateGroups="AUTHORITY_OR_AGENCY"><extensionElements><rm:workflowNode stateCode="CONTRACT_AUTHORITY_REVIEWING" nodeType="USER_TASK" laneName="科技主管部门/专业机构" responsibleActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" responsibleActorName="科技主管部门/专业机构" candidateRoleCode="SCIENCE_ADMIN" operationMode="PROXY_INPUT" representedActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" representedActorName="科技主管部门/专业机构" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="AUTHORITY_CONTRACT_REVIEW_FILE" materialTypeName="主管部门合同审核文件" requirementTiming="BEFORE_SUBMIT" required="false" minCount="0" usageType="PROOF_FILE" allowedFileTypes="pdf,jpg,png" maxFileSizeMb="20"/></extensionElements></userTask>
    <exclusiveGateway id="AuthorityReviewGateway" name="主管部门审核结果"><extensionElements><rm:workflowNode nodeType="GATEWAY" laneName="科技主管部门/专业机构" responsibleActorCode="SYSTEM" responsibleActorName="系统" operationMode="SYSTEM_AUTO" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/></extensionElements></exclusiveGateway>
    <userTask id="PrintPdfContractTask" name="打印PDF合同书" flowable:assignee="${projectLeader}"><extensionElements><rm:workflowNode stateCode="CONTRACT_PDF_PRINTING" nodeType="USER_TASK" laneName="项目负责人" responsibleActorCode="PROJECT_LEADER" responsibleActorName="项目负责人" candidateRoleCode="PROJECT_LEADER" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="CONTRACT_PDF" materialTypeName="PDF合同书" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="SUBMITTED_FILE" allowedFileTypes="pdf" maxFileSizeMb="50"/></extensionElements></userTask>
    <userTask id="LeaderSignTask" name="项目负责人签字" flowable:assignee="${projectLeader}"><extensionElements><rm:workflowNode stateCode="CONTRACT_LEADER_SIGNING" nodeType="USER_TASK" laneName="项目负责人" responsibleActorCode="PROJECT_LEADER" responsibleActorName="项目负责人" candidateRoleCode="PROJECT_LEADER" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="LEADER_SIGNED_CONTRACT" materialTypeName="项目负责人签字合同" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="SIGNED_FILE" allowedFileTypes="pdf,jpg,png" maxFileSizeMb="50"/></extensionElements></userTask>
    <userTask id="SchoolSealTask" name="学校盖章" flowable:candidateGroups="SCHOOL_SEAL_ADMIN"><extensionElements><rm:workflowNode stateCode="CONTRACT_SCHOOL_SEALING" nodeType="USER_TASK" laneName="学校" responsibleActorCode="SCHOOL" responsibleActorName="学校" candidateRoleCode="SCIENCE_ADMIN" operationMode="PROXY_INPUT" representedActorCode="SCHOOL" representedActorName="学校" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="SCHOOL_SEALED_CONTRACT" materialTypeName="学校盖章合同" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="SIGNED_FILE" allowedFileTypes="pdf,jpg,png" maxFileSizeMb="50"/></extensionElements></userTask>
    <userTask id="AuthoritySealTask" name="主管部门或专业机构盖章" flowable:candidateGroups="AUTHORITY_OR_AGENCY"><extensionElements><rm:workflowNode stateCode="CONTRACT_AUTHORITY_SEALING" nodeType="USER_TASK" laneName="科技主管部门/专业机构" responsibleActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" responsibleActorName="科技主管部门/专业机构" candidateRoleCode="SCIENCE_ADMIN" operationMode="PROXY_INPUT" representedActorCode="AUTHORITY_OR_PROFESSIONAL_AGENCY" representedActorName="科技主管部门/专业机构" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="AUTHORITY_SEALED_CONTRACT" materialTypeName="主管部门或专业机构盖章合同" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="SIGNED_FILE" allowedFileTypes="pdf,jpg,png" maxFileSizeMb="50"/></extensionElements></userTask>
    <userTask id="ArchiveContractTask" name="返回科技处、项目负责人存档" flowable:candidateGroups="SCIENCE_OFFICE_ADMIN"><extensionElements><rm:workflowNode stateCode="CONTRACT_ARCHIVING" nodeType="USER_TASK" laneName="科技处" responsibleActorCode="SCIENCE_OFFICE" responsibleActorName="科技处" candidateRoleCode="SCIENCE_ADMIN" operationMode="SELF_OPERATE" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:materialRequirement materialTypeCode="ARCHIVED_CONTRACT" materialTypeName="归档合同文件" requirementTiming="BEFORE_SUBMIT" required="true" minCount="1" usageType="PROOF_FILE" allowedFileTypes="pdf" maxFileSizeMb="50"/><rm:documentConfig documentTypeCode="CONTRACT_ARCHIVE_FORM" documentTypeName="纵向项目合同归档单" generateTiming="ON_NODE_COMPLETE" templateCode="tpl_contract_archive_form" outputMaterialTypeCode="CONTRACT_ARCHIVE_FORM_PDF" outputMaterialTypeName="纵向项目合同归档单PDF" required="true"/></extensionElements></userTask>
    <endEvent id="ApprovedEndEvent" name="合同流程完成"><extensionElements><rm:workflowNode stateCode="CONTRACT_APPROVED" nodeType="END_EVENT" laneName="科技处" responsibleActorCode="SYSTEM" responsibleActorName="系统" operationMode="SYSTEM_AUTO" processKey="CONTRACT_PROCESS" moduleType="CONTRACT"/><rm:documentConfig documentTypeCode="SIGNED_CONTRACT_DOCUMENT" documentTypeName="正式签署合同文件" generateTiming="ON_PROCESS_END" templateCode="tpl_signed_contract_document" outputMaterialTypeCode="SIGNED_CONTRACT_DOCUMENT_PDF" outputMaterialTypeName="正式签署合同文件PDF" required="true"/></extensionElements></endEvent>
    <sequenceFlow id="Flow_Start_AuthorityApprove" sourceRef="StartEvent" targetRef="AuthorityApproveProjectTask"><extensionElements><rm:transition eventType="CONTRACT_PROCESS_STARTED" result="START" conditionType="NONE" actionKeys="SYSTEM_AUTO" sourceRef="StartEvent" targetRef="AuthorityApproveProjectTask" sourceStateCode="CONTRACT_START" targetStateCode="CONTRACT_PROJECT_APPROVED"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_AuthorityApprove_Fill" sourceRef="AuthorityApproveProjectTask" targetRef="FillContractTask"><extensionElements><rm:transition eventType="PROJECT_APPROVAL_REGISTERED" result="APPROVED" conditionType="NONE" actionKeys="CREATE_CONTRACT_FILL_TASK" sourceRef="AuthorityApproveProjectTask" targetRef="FillContractTask" sourceStateCode="CONTRACT_PROJECT_APPROVED" targetStateCode="CONTRACT_DRAFT"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_Fill_DeptReview" sourceRef="FillContractTask" targetRef="DeptReviewTask"><extensionElements><rm:transition eventType="CONTRACT_CONFIRMED_SUBMIT" result="SUBMITTED" conditionType="NONE" actionKeys="CREATE_DEPT_CONTRACT_REVIEW_TASK" sourceRef="FillContractTask" targetRef="DeptReviewTask" sourceStateCode="CONTRACT_DRAFT" targetStateCode="CONTRACT_DEPT_REVIEWING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_DeptReview_Gateway" sourceRef="DeptReviewTask" targetRef="DeptReviewGateway"><extensionElements><rm:transition eventType="DEPT_CONTRACT_REVIEW_FINISHED" result="REVIEW_FINISHED" conditionType="NONE" actionKeys="EVALUATE_DEPT_CONTRACT_REVIEW_RESULT" sourceRef="DeptReviewTask" targetRef="DeptReviewGateway" sourceStateCode="CONTRACT_DEPT_REVIEWING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_DeptReject_Return" name="不通过，返回申请人修改" sourceRef="DeptReviewGateway" targetRef="FillContractTask">
      <extensionElements><rm:transition eventType="DEPT_CONTRACT_REJECT" result="RETURNED" conditionType="SIMPLE_BOOL" conditionKey="deptContractApproved" conditionValue="false" actionKeys="RETURN_CONTRACT_TO_LEADER" sourceRef="DeptReviewGateway" targetRef="FillContractTask" targetStateCode="CONTRACT_DRAFT"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${deptContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_DeptPass_ScienceReview" name="通过" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeReviewTask">
      <extensionElements><rm:transition eventType="DEPT_CONTRACT_APPROVE" result="APPROVED" conditionType="SIMPLE_BOOL" conditionKey="deptContractApproved" conditionValue="true" actionKeys="CREATE_SCIENCE_CONTRACT_REVIEW_TASK" sourceRef="DeptReviewGateway" targetRef="ScienceOfficeReviewTask" targetStateCode="CONTRACT_SCIENCE_REVIEWING"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${deptContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ScienceReview_Gateway" sourceRef="ScienceOfficeReviewTask" targetRef="ScienceOfficeReviewGateway"><extensionElements><rm:transition eventType="SCIENCE_CONTRACT_REVIEW_FINISHED" result="REVIEW_FINISHED" conditionType="NONE" actionKeys="EVALUATE_SCIENCE_CONTRACT_REVIEW_RESULT" sourceRef="ScienceOfficeReviewTask" targetRef="ScienceOfficeReviewGateway" sourceStateCode="CONTRACT_SCIENCE_REVIEWING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_ScienceReject_Return" name="不通过，返回申请人修改" sourceRef="ScienceOfficeReviewGateway" targetRef="FillContractTask">
      <extensionElements><rm:transition eventType="SCIENCE_CONTRACT_REJECT" result="RETURNED" conditionType="SIMPLE_BOOL" conditionKey="scienceContractApproved" conditionValue="false" actionKeys="RETURN_CONTRACT_TO_LEADER" sourceRef="ScienceOfficeReviewGateway" targetRef="FillContractTask" targetStateCode="CONTRACT_DRAFT"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${scienceContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_SciencePass_AuthorityReview" name="通过" sourceRef="ScienceOfficeReviewGateway" targetRef="AuthorityReviewTask">
      <extensionElements><rm:transition eventType="SCIENCE_CONTRACT_APPROVE" result="APPROVED" conditionType="SIMPLE_BOOL" conditionKey="scienceContractApproved" conditionValue="true" actionKeys="CREATE_AUTHORITY_CONTRACT_REVIEW_TASK" sourceRef="ScienceOfficeReviewGateway" targetRef="AuthorityReviewTask" targetStateCode="CONTRACT_AUTHORITY_REVIEWING"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${scienceContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityReview_Gateway" sourceRef="AuthorityReviewTask" targetRef="AuthorityReviewGateway"><extensionElements><rm:transition eventType="AUTHORITY_CONTRACT_REVIEW_FINISHED" result="REVIEW_FINISHED" conditionType="NONE" actionKeys="EVALUATE_AUTHORITY_CONTRACT_REVIEW_RESULT" sourceRef="AuthorityReviewTask" targetRef="AuthorityReviewGateway" sourceStateCode="CONTRACT_AUTHORITY_REVIEWING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_AuthorityReject_Return" name="不通过，返回申请人修改" sourceRef="AuthorityReviewGateway" targetRef="FillContractTask">
      <extensionElements><rm:transition eventType="AUTHORITY_CONTRACT_REJECT" result="RETURNED" conditionType="SIMPLE_BOOL" conditionKey="authorityContractApproved" conditionValue="false" actionKeys="RETURN_CONTRACT_TO_LEADER" sourceRef="AuthorityReviewGateway" targetRef="FillContractTask" targetStateCode="CONTRACT_DRAFT"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${authorityContractApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AuthorityPass_Print" name="通过" sourceRef="AuthorityReviewGateway" targetRef="PrintPdfContractTask">
      <extensionElements><rm:transition eventType="AUTHORITY_CONTRACT_APPROVE" result="APPROVED" conditionType="SIMPLE_BOOL" conditionKey="authorityContractApproved" conditionValue="true" actionKeys="CREATE_PRINT_CONTRACT_TASK" sourceRef="AuthorityReviewGateway" targetRef="PrintPdfContractTask" targetStateCode="CONTRACT_PDF_PRINTING"/></extensionElements><conditionExpression xsi:type="tFormalExpression">${authorityContractApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Print_LeaderSign" sourceRef="PrintPdfContractTask" targetRef="LeaderSignTask"><extensionElements><rm:transition eventType="CONTRACT_PDF_PRINTED" result="PDF_PRINTED" conditionType="NONE" actionKeys="CREATE_LEADER_SIGN_TASK" sourceRef="PrintPdfContractTask" targetRef="LeaderSignTask" sourceStateCode="CONTRACT_PDF_PRINTING" targetStateCode="CONTRACT_LEADER_SIGNING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_LeaderSign_SchoolSeal" sourceRef="LeaderSignTask" targetRef="SchoolSealTask"><extensionElements><rm:transition eventType="LEADER_SIGN_COMPLETED" result="SIGNED" conditionType="NONE" actionKeys="CREATE_SCHOOL_SEAL_TASK" sourceRef="LeaderSignTask" targetRef="SchoolSealTask" sourceStateCode="CONTRACT_LEADER_SIGNING" targetStateCode="CONTRACT_SCHOOL_SEALING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_SchoolSeal_AuthoritySeal" sourceRef="SchoolSealTask" targetRef="AuthoritySealTask"><extensionElements><rm:transition eventType="SCHOOL_SEAL_COMPLETED" result="SEALED" conditionType="NONE" actionKeys="CREATE_AUTHORITY_SEAL_TASK" sourceRef="SchoolSealTask" targetRef="AuthoritySealTask" sourceStateCode="CONTRACT_SCHOOL_SEALING" targetStateCode="CONTRACT_AUTHORITY_SEALING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_AuthoritySeal_Archive" sourceRef="AuthoritySealTask" targetRef="ArchiveContractTask"><extensionElements><rm:transition eventType="AUTHORITY_SEAL_COMPLETED" result="SEALED" conditionType="NONE" actionKeys="CREATE_CONTRACT_ARCHIVE_TASK" sourceRef="AuthoritySealTask" targetRef="ArchiveContractTask" sourceStateCode="CONTRACT_AUTHORITY_SEALING" targetStateCode="CONTRACT_ARCHIVING"/></extensionElements></sequenceFlow>
    <sequenceFlow id="Flow_Archive_End" sourceRef="ArchiveContractTask" targetRef="ApprovedEndEvent"><extensionElements><rm:transition eventType="CONTRACT_ARCHIVED" result="PROCESS_COMPLETED" conditionType="NONE" actionKeys="GENERATE_CONTRACT_DOCUMENTS" sourceRef="ArchiveContractTask" targetRef="ApprovedEndEvent" sourceStateCode="CONTRACT_ARCHIVING" targetStateCode="CONTRACT_APPROVED"/></extensionElements></sequenceFlow>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_researchProjectContractFillProcess">
